{
  "[cpp]": {
    "editor.defaultFormatter": "xaver.clang-format"
  },
  "C_Cpp.default.configurationProvider": "ms-vscode.cmake-tools",
  "cmake.ignoreKitEnv": false,
  "cmake.configureArgs": [
    "-DUSE_CCACHE=YES",
    "-DCMAKE_C_FLAGS_RELEASE=\"-march=native -O2 -pipe -fno-plt -std=c++20\"",
    "-DCMAKE_CC_FLAGS_RELEASE=\"-march=native -O2 -pipe -fno-plt -std=c++20\"",
    "-DCMAKE_CXX_FLAGS_RELEASE=\"-march=native -O2 -pipe -fno-plt -std=c++20\"",
    "-DCMAKE_C_FLAGS_DEBUG=-std=c++20 -g -fvar-tracking-assignments",
    "-DCMAKE_CC_FLAGS_DEBUG=-std=c++20 -g -fvar-tracking-assignments",
    "-DCMAKE_CXX_FLAGS_DEBUG=-std=c++20 -g -fvar-tracking-assignments"
  ],
  "files.associations": {
    "iostream": "cpp",
    "cmath": "cpp",
    "complex": "cpp",
    "string": "cpp",
    "limits": "cpp"
  }
}
